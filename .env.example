APP_NAME="InvenTrack"
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inventrack
DB_USERNAME=root
DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────
# FIREBASE REALTIME DATABASE CONFIGURATION
# Ganti URL di bawah ini dengan URL Firebase project Anda.
# Format: https://<project-id>-default-rtdb.firebaseio.com
# ─────────────────────────────────────────────────────────────────

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
